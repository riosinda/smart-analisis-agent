# Proveedor de LLM activo: "openai" | "gemini" | "ollama"
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Gemini ---
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local, no requiere API key) ---
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Parámetros compartidos del LLM
TEMPERATURE=0.7
MAX_TOKENS=4096
